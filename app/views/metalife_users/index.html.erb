<% content_for(:title) { "MetaLifeユーザー管理" } %>

<div class="max-w-7xl mx-auto pb-4"
     data-controller="linkable-select"
     data-linkable-select-members-value="<%= linkable_members_json.to_json %>"
     data-linkable-select-students-value="<%= linkable_students_json.to_json %>">
  <div class="mb-8 sm:mb-12">
    <div class="mb-4">
      <h3 class="text-xl font-bold text-gray-900">MetaLifeユーザー管理</h3>
    </div>

    <div class="mb-4 border-b border-gray-200">
      <nav class="flex -mb-px space-x-8" aria-label="Tabs">
        <%= link_to "未紐付け・最近の活動あり (#{@unlinked_active_count})",
              metalife_users_path,
              class: "whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium #{@scope == :unlinked_active ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'}" %>
        <%= link_to "未紐付け・活動なし (#{@unlinked_inactive_count})",
              metalife_users_path(scope: :unlinked_inactive),
              class: "whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium #{@scope == :unlinked_inactive ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'}" %>
        <%= link_to "紐付け済み (#{@linked_count})",
              metalife_users_path(scope: :linked),
              class: "whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium #{@scope == :linked ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'}" %>
      </nav>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% @metalife_users.each do |user| %>
        <div class="bg-white shadow-md rounded-lg p-5">
          <h4 class="text-base font-semibold text-gray-900"><%= user.name %></h4>
          <p class="mt-1 text-sm text-gray-500">MetaLife ID: <%= user.metalife_id %></p>

          <div class="mt-2 text-sm">
            <% if user.linkable.present? %>
              <span class="text-gray-500"><%= user.linkable.class.name %>:</span>
              <% if user.linkable.is_a?(Member) %>
                <%= link_to user.linkable.name, member_path(user.linkable), class: "text-indigo-600 hover:text-indigo-800" %>
              <% elsif user.linkable.is_a?(Student) %>
                <%= link_to user.linkable.name, student_path(user.linkable), class: "text-indigo-600 hover:text-indigo-800" %>
              <% end %>
            <% else %>
              <span class="text-gray-400">未紐付け</span>
            <% end %>
          </div>

          <p class="mt-2 text-xs text-gray-400">
            作成: <%= user.created_at.strftime("%Y-%m-%d %H:%M") %>
            <span class="mx-1">·</span>
            更新: <%= user.updated_at.strftime("%Y-%m-%d %H:%M") %>
          </p>

          <div class="mt-3 pt-3 border-t border-gray-100">
            <%= form_with url: metalife_user_path(user), method: :patch, local: true, class: "space-y-2" do |f| %>
              <div class="flex items-center gap-2">
                <%= f.select :linkable_type,
                    options_for_select([["未紐付け", ""], ["Member", "Member"], ["Student", "Student"]], user.linkable_type),
                    {},
                    class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm",
                    data: { action: "change->linkable-select#typeChanged" } %>

                <%= f.select :linkable_id, grouped_options_for_select(linkable_options_for(user), user.linkable_id), {}, class: "rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
              </div>

              <%= f.submit "更新", class: "bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 text-sm rounded-md" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
