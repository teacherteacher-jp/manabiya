<% content_for(:title) { "問診一覧" } %>

<h2 class="text-xl md:text-2xl font-bold mb-4">問診一覧</h2>


<% if @intakes.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @intakes.each do |intake| %>
      <div class="bg-white shadow-md rounded-lg p-5">
        <div class="flex items-start justify-between gap-3">
          <h3 class="text-base font-semibold">
            <%= link_to intake.title, intake, class: "text-indigo-600 hover:text-indigo-800" %>
          </h3>
          <% if current_member.admin? %>
            <%= link_to "編集", edit_intake_path(intake), class: "shrink-0 text-sm text-gray-500 hover:text-gray-700" %>
          <% end %>
        </div>
        <% if intake.description.present? %>
          <p class="mt-2 text-sm text-gray-500 line-clamp-3"><%= intake.description %></p>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-500">利用できる問診がありません。</p>
<% end %>

<% if current_member.admin? %>
  <%= link_to "新規作成", new_intake_path, class: "fixed bottom-4 right-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-md shadow-lg print:hidden" %>
<% end %>
