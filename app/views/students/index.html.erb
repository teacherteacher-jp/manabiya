<div class="max-w-7xl mx-auto pb-4">
  <%= render "shared/access_restriction_notice" %>
  <div class="mb-8 sm:mb-12">
    <div class="mb-4">
      <h3 class="text-xl font-bold text-gray-900">生徒一覧</h3>
    </div>

    <div class="mb-4 border-b border-gray-200">
      <nav class="flex -mb-px space-x-8" aria-label="Tabs">
        <%= link_to "利用中",
              students_path,
              class: "whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium #{@scope == :active ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'}" %>
        <%= link_to "それ以外",
              students_path(scope: :inactive),
              class: "whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium #{@scope == :inactive ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'}" %>
      </nav>
    </div>

    <div class="overflow-x-auto shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              名前
            </th>
            <th scope="col" class="hidden sm:table-cell px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              学年
            </th>
            <% if @scope == :inactive %>
              <th scope="col" class="hidden sm:table-cell px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                状況
              </th>
            <% end %>
            <th scope="col" class="hidden md:table-cell px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              保護者
            </th>
            <th scope="col" class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              最近の入室
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @students.each do |student| %>
            <tr class="hover:bg-gray-50">
              <td class="px-3 sm:px-6 py-4 text-sm font-medium">
                <div class="flex flex-col">
                  <%= link_to student.name, student_path(student), class: "text-indigo-600 hover:text-indigo-900" %>
                  <div class="sm:hidden text-xs text-gray-500 mt-1">
                    <%= student.grade %>
                    <% if @scope == :inactive %>
                      <span class="mx-1">•</span>
                      <%= student.status_in_japanese %>
                    <% end %>
                    <% if student.guardians.any? %>
                      <span class="mx-1">•</span>
                      保護者: <%= student.guardians.map { |g| link_to g.name, member_path(g), class: "text-indigo-600 hover:text-indigo-900" }.join("、").html_safe %>
                    <% end %>
                  </div>
                  <div class="hidden sm:block md:hidden text-xs text-gray-500 mt-1">
                    <% if student.guardians.any? %>
                      保護者: <%= student.guardians.map { |g| link_to g.name, member_path(g), class: "text-indigo-600 hover:text-indigo-900" }.join("、").html_safe %>
                    <% end %>
                  </div>
                </div>
              </td>
              <td class="hidden sm:table-cell px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= student.grade %>
              </td>
              <% if @scope == :inactive %>
                <td class="hidden sm:table-cell px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= student.status_in_japanese %>
                </td>
              <% end %>
              <td class="hidden md:table-cell px-6 py-4 text-sm">
                <% if student.guardians.any? %>
                  <%= student.guardians.map { |g| link_to g.name, member_path(g), class: "text-indigo-600 hover:text-indigo-900" }.join("、").html_safe %>
                <% else %>
                  <span class="text-gray-400">未登録</span>
                <% end %>
              </td>
              <td class="px-3 sm:px-6 py-4 text-sm text-gray-500">
                <% if entry = student.latest_entry %>
                  <div class="whitespace-nowrap">
                    <%= entry[:date].strftime("%-m/%d") %>
                    <span class="hidden sm:inline"><%= entry[:time].strftime("%-H:%M") %></span>
                    <span class="sm:hidden text-xs block"><%= entry[:time].strftime("%-H:%M") %></span>
                  </div>
                <% else %>
                  <span class="text-gray-400">-</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<% if current_member.admin? %>
  <%= link_to "生徒を追加", new_student_path, class: "fixed bottom-4 right-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-md shadow-lg print:hidden" %>
<% end %>
