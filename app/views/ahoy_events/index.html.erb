<% content_for(:title) { "利用ログ" } %>

<div class="p-6">
  <h1 class="text-xl md:text-2xl font-bold mb-4">利用ログ</h1>

  <div class="bg-white rounded-lg shadow-sm p-4 mb-4">
    <%= form_with url: ahoy_events_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-end" do |f| %>
      <div class="flex-1 min-w-[180px]">
        <%= f.label :member_id, "メンバー", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :member_id,
            options_from_collection_for_select(@event_members, :id, :name, params[:member_id]),
            { include_blank: "すべて" },
            class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div class="flex-1 min-w-[180px]">
        <%= f.label :name, "イベント名", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :name,
            options_for_select(@event_names, params[:name]),
            { include_blank: "すべて" },
            class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div class="flex-1 min-w-[180px]">
        <%= f.label :properties, "プロパティ", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :properties,
            value: params[:properties],
            placeholder: "キーワード検索",
            class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div class="flex gap-2">
        <%= f.submit "絞り込み", class: "px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
        <%= link_to "クリア", ahoy_events_path, class: "px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-300" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-sm p-4">
    <p class="text-sm text-gray-500 mb-3"><%= @events.total_count %> 件</p>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">日時</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">メンバー</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">イベント名</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">プロパティ</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @events.each do |event| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= event.time.strftime("%Y-%m-%d %H:%M:%S") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <% if event.member %>
                  <%= link_to event.member.name, member_path(event.member), class: "text-indigo-600 hover:text-indigo-900" %>
                <% else %>
                  <span class="text-gray-400">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900">
                <%= event.name %>
              </td>
              <td class="px-6 py-4 text-sm font-mono text-gray-600 max-w-md truncate">
                <%= event.properties.except("authenticity_token").to_json %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-4">
    <%= paginate @events %>
  </div>
</div>
