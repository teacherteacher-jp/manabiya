<% content_for(:title) { "問診レポート一覧" } %>

<h2 class="text-xl md:text-2xl font-bold mb-6">問診レポート一覧</h2>

<% if @intake_reports.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @intake_reports.each do |report| %>
      <div class="bg-white shadow-md rounded-lg p-5">
        <h3 class="text-base font-semibold">
          <%= link_to report.intake_session.intake.title, intake_path(report.intake_session.intake), class: "text-indigo-600 hover:text-indigo-800" %>
        </h3>
        <p class="mt-1 text-sm text-gray-500">
          <%= report.intake_session.member.name %>
          <span class="mx-1">·</span>
          <%= report.created_at.strftime("%Y-%m-%d %H:%M") %>
        </p>
        <div class="mt-3 text-right">
          <%= link_to "レポートを見る →", intake_report_path(report), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-500">まだレポートがありません。</p>
<% end %>
